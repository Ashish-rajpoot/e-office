ca4\u0ccd\u0ca4\u0ca6\u0cc6.","termsUseLi5":"\u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cb8\u0c82\u0ca6\u0cb0\u0ccd\u0cad\u0c97\u0cb3\u0cb2\u0ccd\u0cb2\u0cbf \u0cb8\u0cb0\u0ccd\u0c95\u0cbe\u0cb0\u0cbf \u0cb8\u0c9a\u0cbf\u0cb5\u0cbe\u0cb2\u0caf/\u0c87\u0cb2\u0cbe\u0c96\u0cc6/\u0cb8\u0c82\u0cb8\u0ccd\u0ca5\u0cc6\u0caf\u0cc1 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cb5\u0cc6\u0c9a\u0ccd\u0c9a, \u0ca8\u0cb7\u0ccd\u0c9f \u0c85\u0ca5\u0cb5\u0cbe \u0cb9\u0cbe\u0ca8\u0cbf\u0c97\u0cc6 \u0cb9\u0cca\u0ca3\u0cc6\u0c97\u0cbe\u0cb0\u0ca8\u0cbe\u0c97\u0cbf\u0cb0\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2, \u0c87\u0ca6\u0cb0\u0cb2\u0ccd\u0cb2\u0cbf \u0cae\u0cbf\u0ca4\u0cbf\u0caf\u0cbf\u0cb2\u0ccd\u0cb2\u0ca6\u0cc6, \u0caa\u0cb0\u0ccb\u0c95\u0ccd\u0cb7 \u0c85\u0ca5\u0cb5\u0cbe \u0caa\u0cb0\u0cbf\u0ca3\u0cbe\u0cae\u0c95\u0cbe\u0cb0\u0cbf \u0ca8\u0cb7\u0ccd\u0c9f \u0c85\u0ca5\u0cb5\u0cbe \u0cb9\u0cbe\u0ca8\u0cbf, \u0c85\u0ca5\u0cb5\u0cbe \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cb5\u0cc6\u0c9a\u0ccd\u0c9a, \u0ca8\u0cb7\u0ccd\u0c9f \u0c85\u0ca5\u0cb5\u0cbe \u0cb9\u0cbe\u0ca8\u0cbf, \u0ca1\u0cc7\u0c9f\u0cbe\u0ca6 \u0cac\u0cb3\u0c95\u0cc6\u0caf\u0cbf\u0c82\u0ca6 \u0c85\u0ca5\u0cb5\u0cbe \u0cac\u0cb3\u0c95\u0cc6\u0caf \u0ca8\u0cb7\u0ccd\u0c9f\u0ca6\u0cbf\u0c82\u0ca6 \u0c89\u0c82\u0c9f\u0cbe\u0c97\u0cc1\u0ca4\u0ccd\u0ca4\u0ca6\u0cc6.","termsUseLi6":"Parichey \u0ca8\u0cc0\u0ca1\u0cc1\u0cb5 \u0cb8\u0cc7\u0cb5\u0cc6\u0caf\u0cc1 \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0cb5\u0cc8\u0caf\u0c95\u0ccd\u0ca4\u0cbf\u0c95 \u0cac\u0cb3\u0c95\u0cc6\u0c97\u0cc6 \u0cae\u0cbe\u0ca4\u0ccd\u0cb0 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0cb5\u0cbe\u0ca3\u0cbf\u0c9c\u0ccd\u0caf \u0cb6\u0ccb\u0cb7\u0ca3\u0cc6\u0c97\u0cc6 \u0c85\u0cb2\u0ccd\u0cb2. \u0ca8\u0cc0\u0cb5\u0cc1 Parichey \u0ca8\u0cbf\u0c82\u0ca6 \u0ca1\u0cbf\u0c95\u0c82\u0caa\u0cc8\u0cb2\u0ccd, \u0cb0\u0cbf\u0cb5\u0cb0\u0ccd\u0cb8\u0ccd \u0c8e\u0c82\u0c9c\u0cbf\u0ca8\u0cbf\u0caf\u0cb0\u0ccd, \u0ca1\u0cbf\u0cb8\u0ccd\u0c85\u0cb8\u0cc6\u0c82\u0cac\u0cb2\u0ccd, \u0cac\u0cbe\u0ca1\u0cbf\u0c97\u0cc6, \u0c97\u0cc1\u0ca4\u0ccd\u0ca4\u0cbf\u0c97\u0cc6, \u0cb8\u0cbe\u0cb2, \u0cae\u0cbe\u0cb0\u0cbe\u0c9f, \u0c89\u0caa\u0caa\u0cb0\u0cb5\u0cbe\u0ca8\u0c97\u0cbf \u0c85\u0ca5\u0cb5\u0cbe \u0cb5\u0ccd\u0caf\u0cc1\u0ca4\u0ccd\u0caa\u0ca8\u0ccd\u0ca8 \u0c95\u0cc3\u0ca4\u0cbf\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb0\u0c9a\u0cbf\u0cb8\u0cac\u0cbe\u0cb0\u0ca6\u0cc1. \u0c85\u0caa\u0ccd\u0cb2\u0cbf\u0c95\u0cc7\u0cb6\u0ca8\u0ccd/\u0cb8\u0cc8\u0c9f\u0ccd \u0c86\u0cb0\u0ccd\u0c95\u0cbf\u0c9f\u0cc6\u0c95\u0ccd\u0c9a\u0cb0\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cbf\u0cb0\u0ccd\u0ca7\u0cb0\u0cbf\u0cb8\u0cb2\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0cac\u0cb3\u0c95\u0cc6, \u0cb5\u0cc8\u0caf\u0c95\u0ccd\u0ca4\u0cbf\u0c95 \u0c97\u0cc1\u0cb0\u0cc1\u0ca4\u0cc1\u0c97\u0cb3\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0cac\u0cb3\u0c95\u0cc6\u0ca6\u0cbe\u0cb0\u0cb0 \u0cac\u0c97\u0ccd\u0c97\u0cc6 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb9\u0cca\u0cb0\u0ca4\u0cc6\u0c97\u0cc6\u0caf\u0cb2\u0cc1 \u0ca8\u0cc0\u0cb5\u0cc1 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0ca8\u0cc6\u0c9f\u0ccd\u200c\u0cb5\u0cb0\u0ccd\u0c95\u0ccd \u0cae\u0cbe\u0ca8\u0cbf\u0c9f\u0cb0\u0cbf\u0c82\u0c97\u0ccd \u0c85\u0ca5\u0cb5\u0cbe \u0ca1\u0cbf\u0cb8\u0ccd\u0c95\u0cb5\u0cb0\u0cbf \u0cb8\u0cbe\u0cab\u0ccd\u0c9f\u0ccd\u200c\u0cb5\u0cc7\u0cb0\u0ccd \u0c85\u0ca8\u0ccd\u0ca8\u0cc1 \u0cac\u0cb3\u0cb8\u0cac\u0cbe\u0cb0\u0ca6\u0cc1. NIC \u0caf \u0caa\u0cc2\u0cb0\u0ccd\u0cb5 \u0cb2\u0cbf\u0c96\u0cbf\u0ca4 \u0c85\u0ca8\u0cc1\u0cae\u0ca4\u0cbf\u0caf\u0cbf\u0cb2\u0ccd\u0cb2\u0ca6\u0cc6 Parichey \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0c85\u0ca6\u0cb0 \u0cb5\u0cbf\u0cb7\u0caf\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0cae\u0cc7\u0cb2\u0ccd\u0cb5\u0cbf\u0c9a\u0cbe\u0cb0\u0ca3\u0cc6 \u0cae\u0cbe\u0ca1\u0cb2\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0ca8\u0c95\u0cb2\u0cbf\u0cb8\u0cb2\u0cc1 \u0ca8\u0cc0\u0cb5\u0cc1 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cb0\u0ccb\u0cac\u0ccb\u0c9f\u0ccd, \u0cb8\u0ccd\u0caa\u0cc8\u0ca1\u0cb0\u0ccd, \u0c87\u0ca4\u0cb0 \u0cb8\u0ccd\u0cb5\u0caf\u0c82\u0c9a\u0cbe\u0cb2\u0cbf\u0ca4 \u0cb8\u0cbe\u0cab\u0ccd\u0c9f\u0ccd\u200c\u0cb5\u0cc7\u0cb0\u0ccd \u0c85\u0ca5\u0cb5\u0cbe \u0cb8\u0cbe\u0ca7\u0ca8 \u0c85\u0ca5\u0cb5\u0cbe \u0cb9\u0cb8\u0ccd\u0ca4\u0c9a\u0cbe\u0cb2\u0cbf\u0ca4 \u0caa\u0ccd\u0cb0\u0c95\u0ccd\u0cb0\u0cbf\u0caf\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cac\u0cb3\u0cb8\u0cac\u0cbe\u0cb0\u0ca6\u0cc1. \u0c88 \u0cac\u0cb3\u0c95\u0cc6\u0caf \u0ca8\u0cbf\u0caf\u0cae\u0c97\u0cb3 \u0cb9\u0c95\u0ccd\u0c95\u0cc1\u0cb8\u0ccd\u0cb5\u0cbe\u0cae\u0ccd\u0caf \u0ca8\u0cc0\u0ca4\u0cbf\u0caf\u0cbf\u0c82\u0ca6 \u0c85\u0ca8\u0cc1\u0cae\u0ca4\u0cbf\u0cb8\u0cb2\u0cbe\u0ca6 \u0cae\u0c9f\u0ccd\u0c9f\u0cbf\u0c97\u0cc6 \u0cb9\u0cca\u0cb0\u0ca4\u0cc1\u0caa\u0ca1\u0cbf\u0cb8\u0cbf, \u0ca8\u0cc0\u0cb5\u0cc1 Parichey \u0ca8 \u0c8e\u0cb2\u0ccd\u0cb2\u0cbe \u0c85\u0ca5\u0cb5\u0cbe \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cad\u0cbe\u0c97\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb5\u0cbe\u0ca3\u0cbf\u0c9c\u0ccd\u0caf, \u0cb2\u0cbe\u0cad\u0cb0\u0cb9\u0cbf\u0ca4 \u0c85\u0ca5\u0cb5\u0cbe \u0cb8\u0cbe\u0cb0\u0ccd\u0cb5\u0c9c\u0ca8\u0cbf\u0c95 \u0c89\u0ca6\u0ccd\u0ca6\u0cc7\u0cb6\u0c97\u0cb3\u0cbf\u0c97\u0cbe\u0c97\u0cbf \u0ca8\u0c95\u0cb2\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2, \u0cae\u0cbe\u0cb0\u0ccd\u0caa\u0ca1\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2, \u0caa\u0cc1\u0ca8\u0cb0\u0cc1\u0ca4\u0ccd\u0caa\u0cbe\u0ca6\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2, \u0cae\u0cb0\u0cc1\u0caa\u0ccd\u0cb0\u0c95\u0c9f\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2, \u0cb5\u0cbf\u0ca4\u0cb0\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2, \u0caa\u0ccd\u0cb0\u0ca6\u0cb0\u0ccd\u0cb6\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2 \u0c85\u0ca5\u0cb5\u0cbe \u0cb0\u0cb5\u0cbe\u0ca8\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2. Parichey \u0ca8 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0c85\u0ca8\u0ca7\u0cbf\u0c95\u0cc3\u0ca4 \u0cac\u0cb3\u0c95\u0cc6.","userResponsibility":"\u0cac\u0cb3\u0c95\u0cc6\u0ca6\u0cbe\u0cb0\u0cb0 \u0c9c\u0cb5\u0cbe\u0cac\u0ccd\u0ca6\u0cbe\u0cb0\u0cbf","userResponsibilityText":"\u0c9c\u0cb5\u0cbe\u0cac\u0ccd\u0ca6\u0cbe\u0cb0\u0cbf\u0caf\u0cc1\u0ca4 \u0cac\u0cb3\u0c95\u0cc6\u0ca6\u0cbe\u0cb0\u0cb0\u0cbe\u0c97\u0cbf, \u0ca8\u0cc0\u0cb5\u0cc1:","userResponsibilityLi1":"\u0cb8\u0cc7\u0cb5\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0ccd\u0cb0\u0cb5\u0cc7\u0cb6\u0cbf\u0cb8\u0cb2\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0caa\u0ccd\u0cb0\u0cb5\u0cc7\u0cb6\u0cbf\u0cb8\u0cb2\u0cc1 \u0ca8\u0cc8\u0cb8\u0cb0\u0ccd\u0c97\u0cbf\u0c95 \u0cb5\u0ccd\u0caf\u0c95\u0ccd\u0ca4\u0cbf\u0caf\u0cbe\u0c97\u0cbf\u0cb0\u0cbf.","userResponsibilityLi2":"\u0caa\u0cb0\u0cbf\u0c9a\u0cc7 \u0cb8\u0cc7\u0cb5\u0cbe \u0c96\u0cbe\u0ca4\u0cc6.","userResponsibilityLi3":"\u0caa\u0cb0\u0cbf\u0c9a\u0caf\u0ccd \u0caa\u0ccb\u0cb0\u0ccd\u0c9f\u0cb2\u0ccd \u0cae\u0cc2\u0cb2\u0c95 \u0cae\u0cbe\u0ca4\u0ccd\u0cb0 \u0caa\u0cb0\u0cbf\u0c9a\u0caf\u0ccd \u0c95\u0cc1\u0cb0\u0cbf\u0ca4\u0cbe\u0ca6 \u0cb5\u0cbf\u0cb5\u0cb0\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0ccd\u0cb0\u0cb5\u0cc7\u0cb6\u0cbf\u0cb8\u0cac\u0cb9\u0cc1\u0ca6\u0cc1, \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0ca8\u0cbf\u0cae\u0c97\u0cc6 \u0ca8\u0cbf\u0cb0\u0ccd\u0ca6\u0cbf\u0cb7\u0ccd\u0c9f\u0cb5\u0cbe\u0c97\u0cbf \u0cb9\u0c82\u0c9a\u0cbf\u0c95\u0cc6 \u0cae\u0cbe\u0ca1\u0cb2\u0cbe\u0ca6 \u0cac\u0cb3\u0c95\u0cc6\u0ca6\u0cbe\u0cb0\u0cb9\u0cc6\u0cb8\u0cb0\u0cc1 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0ca6\u0cc3\u0ca2\u0cc0\u0c95\u0cb0\u0ca3 \u0cb5\u0cbf\u0cb5\u0cb0\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0cae\u0cbe\u0ca4\u0ccd\u0cb0 \u0cac\u0cb3\u0cb8\u0cac\u0cb9\u0cc1\u0ca6\u0cc1.","userResponsibilityLi4":"\u0ca8\u0cc0\u0cb5\u0cc1 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0c95\u0cbe\u0ca8\u0cc2\u0ca8\u0cc1\u0cac\u0cbe\u0cb9\u0cbf\u0cb0, \u0cae\u0cbe\u0ca8\u0cb9\u0cbe\u0ca8\u0cbf\u0c95\u0cb0, \u0c85\u0cb6\u0ccd\u0cb2\u0cc0\u0cb2, \u0c86\u0c95\u0ccd\u0cb0\u0cae\u0ca3\u0c95\u0cbe\u0cb0\u0cbf \u0c85\u0ca5\u0cb5\u0cbe \u0c96\u0c82\u0ca1\u0ca8\u0cc0\u0caf \u0cb5\u0cbf\u0cb7\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0c95\u0cbe\u0ca8\u0cc2\u0ca8\u0ca8\u0ccd\u0ca8\u0cc1 \u0c89\u0cb2\u0ccd\u0cb2\u0c82\u0c98\u0cbf\u0cb8\u0cc1\u0cb5 \u0ca8\u0ca1\u0cb5\u0cb3\u0cbf\u0c95\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb0\u0cc2\u0caa\u0cbf\u0cb8\u0cc1\u0cb5 \u0c85\u0ca5\u0cb5\u0cbe \u0caa\u0ccd\u0cb0\u0ccb\u0ca4\u0ccd\u0cb8\u0cbe\u0cb9\u0cbf\u0cb8\u0cc1\u0cb5 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cb5\u0cbf\u0cb7\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0cb0\u0cbf\u0c9a\u0caf\u0ccd \u0cae\u0cc2\u0cb2\u0c95 \u0cb0\u0cb5\u0cbe\u0ca8\u0cbf\u0cb8\u0cac\u0cbe\u0cb0\u0ca6\u0cc1.","userResponsibilityLi5":"\u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0caa\u0cb0\u0cbf\u0c9a\u0cc7 \u0c96\u0cbe\u0ca4\u0cc6\u0caf\u0cca\u0cb3\u0c97\u0cc6, \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c92\u0ca6\u0c97\u0cbf\u0cb8\u0cb2\u0cc1 \u0ca8\u0cbf\u0cae\u0ccd\u0cae\u0ca8\u0ccd\u0ca8\u0cc1 \u0c95\u0cc7\u0cb3\u0cbf\u0ca6\u0cb0\u0cc6, \u0ca8\u0cc0\u0cb5\u0cc1 \u0c92\u0ca6\u0c97\u0cbf\u0cb8\u0cc1\u0cb5 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0caf\u0cc1 \u0cb8\u0c82\u0caa\u0cc2\u0cb0\u0ccd\u0ca3 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0ca8\u0cbf\u0c96\u0cb0\u0cb5\u0cbe\u0c97\u0cbf\u0cb0\u0cac\u0cc7\u0c95\u0cc1. \u0ca8\u0cc0\u0cb5\u0cc1 \u0c85\u0caa\u0cc2\u0cb0\u0ccd\u0ca3, \u0ca4\u0caa\u0ccd\u0caa\u0cbe\u0ca6 \u0c85\u0ca5\u0cb5\u0cbe \u0cb8\u0cc1\u0cb3\u0ccd\u0cb3\u0cc1 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c92\u0ca6\u0c97\u0cbf\u0cb8\u0cbf\u0ca6\u0cb0\u0cc6, \u0c85\u0ca8\u0ca7\u0cbf\u0c95\u0cc3\u0ca4 \u0c95\u0ccd\u0cb0\u0cbf\u0caf\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cbf\u0cb0\u0ccd\u0cb5\u0cb9\u0cbf\u0cb8\u0cb2\u0cc1 (\u0c85\u0ca5\u0cb5\u0cbe \u0ca8\u0cbf\u0cb0\u0ccd\u0cb5\u0cb9\u0cbf\u0cb8\u0cb2\u0cc1 \u0caa\u0ccd\u0cb0\u0caf\u0ca4\u0ccd\u0ca8\u0cbf\u0cb8\u0cbf\u0ca6\u0cb0\u0cc6) \u0c85\u0ca5\u0cb5\u0cbe \u0caa\u0cb0\u0cbf\u0c9a\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca6\u0cc1\u0cb0\u0cc1\u0caa\u0caf\u0ccb\u0c97\u0caa\u0ca1\u0cbf\u0cb8\u0cbf\u0c95\u0cca\u0c82\u0ca1\u0cb0\u0cc6, \u0c85\u0ca6\u0cc1 \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0caa\u0cb0\u0cbf\u0c9a\u0caf \u0caa\u0ccd\u0cb0\u0cb5\u0cc7\u0cb6\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0c85\u0cae\u0cbe\u0ca8\u0ca4\u0cc1\u0c97\u0cca\u0cb3\u0cbf\u0cb8\u0cac\u0cb9\u0cc1\u0ca6\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0c95\u0cca\u0ca8\u0cc6\u0c97\u0cca\u0cb3\u0cbf\u0cb8\u0cac\u0cb9\u0cc1\u0ca6\u0cc1 \u0c8e\u0c82\u0ca6\u0cc1 \u0ca8\u0cc0\u0cb5\u0cc1 \u0c92\u0caa\u0ccd\u0caa\u0cbf\u0c95\u0cca\u0cb3\u0ccd\u0cb3\u0cc1\u0ca4\u0ccd\u0ca4\u0cc0\u0cb0\u0cbf.","userResponsibilityLi6":"\u0cb8\u0cc1\u0cb3\u0ccd\u0cb3\u0cc1 \u0c85\u0ca5\u0cb5\u0cbe \u0ca6\u0cbe\u0cb0\u0cbf\u0ca4\u0caa\u0ccd\u0caa\u0cbf\u0cb8\u0cc1\u0cb5 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cc0\u0ca1\u0cc1\u0cb5\u0cc1\u0ca6\u0cc1 \u0c97\u0c82\u0cad\u0cc0\u0cb0 \u0c85\u0caa\u0cb0\u0cbe\u0ca7. \u0caa\u0cb0\u0cbf\u0c9a\u0caf\u0ca6 \u0cae\u0cc2\u0cb2\u0c95 \u0c85\u0caa\u0cc2\u0cb0\u0ccd\u0ca3, \u0ca4\u0caa\u0ccd\u0caa\u0cbe\u0ca6 \u0c85\u0ca5\u0cb5\u0cbe \u0cb8\u0cc1\u0cb3\u0ccd\u0cb3\u0cc1 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c92\u0ca6\u0c97\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0ca8\u0ccd\u0ca8\u0cc1 \u0cab\u0cbe\u0cb0\u0ccd\u0cae\u0ccd\u200c\u0ca8\u0cb2\u0ccd\u0cb2\u0cbf \u0c85\u0ca5\u0cb5\u0cbe \u0cb5\u0cc8\u0caf\u0c95\u0ccd\u0ca4\u0cbf\u0c95\u0cb5\u0cbe\u0c97\u0cbf \u0ca4\u0caa\u0ccd\u0caa\u0cbe\u0ca6 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0c92\u0ca6\u0c97\u0cbf\u0cb8\u0cc1\u0cb5\u0c82\u0ca4\u0cc6\u0caf\u0cc7 \u0caa\u0cb0\u0cbf\u0c97\u0ca3\u0cbf\u0cb8\u0cb2\u0cbe\u0c97\u0cc1\u0ca4\u0ccd\u0ca4\u0ca6\u0cc6 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0c87\u0ca6\u0cc1 \u0c95\u0cbe\u0ca8\u0cc2\u0ca8\u0cc1 \u0c95\u0ccd\u0cb0\u0cae \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0cb8\u0cbf\u0cb5\u0cbf\u0cb2\u0ccd \u0c85\u0ca5\u0cb5\u0cbe \u0c95\u0ccd\u0cb0\u0cbf\u0cae\u0cbf\u0ca8\u0cb2\u0ccd \u0ca6\u0c82\u0ca1\u0c97\u0cb3\u0cbf\u0c97\u0cc6 \u0c95\u0cbe\u0cb0\u0ca3\u0cb5\u0cbe\u0c97\u0cac\u0cb9\u0cc1\u0ca6\u0cc1.","userResponsibilityText2":"\u0c88 \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd/\u0caa\u0ccb\u0cb0\u0ccd\u0c9f\u0cb2\u0ccd\u200c\u0ca8\u0cb2\u0ccd\u0cb2\u0cbf \u0c95\u0cbe\u0ca3\u0cbf\u0cb8\u0cbf\u0c95\u0cca\u0c82\u0ca1\u0cbf\u0cb0\u0cc1\u0cb5 \u0cb5\u0cbf\u0cb7\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 NIC \u0caf \u0cb8\u0ccd\u0caa\u0cb7\u0ccd\u0c9f \u0cb2\u0cbf\u0c96\u0cbf\u0ca4 \u0c85\u0ca8\u0cc1\u0cae\u0ca4\u0cbf\u0caf\u0cbf\u0cb2\u0ccd\u0cb2\u0ca6\u0cc6 \u0c8e\u0cb2\u0ccd\u0cb2\u0cbf\u0caf\u0cc2 \u0caa\u0cc1\u0ca8\u0cb0\u0cc1\u0ca4\u0ccd\u0caa\u0cbe\u0ca6\u0cbf\u0cb8\u0cac\u0cbe\u0cb0\u0ca6\u0cc1. \u0c86\u0ca6\u0cbe\u0c97\u0ccd\u0caf\u0cc2, \u0c85\u0ca8\u0cc1\u0cae\u0ca4\u0cbf\u0caf\u0cca\u0c82\u0ca6\u0cbf\u0c97\u0cc6 \u0cb5\u0cbf\u0cb7\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0cc1\u0ca8\u0cb0\u0cc1\u0ca4\u0ccd\u0caa\u0cbe\u0ca6\u0cbf\u0cb8\u0cac\u0cc7\u0c95\u0cbe\u0ca6\u0cb0\u0cc6, \u0c85\u0c82\u0ca4\u0cb9 \u0caa\u0cc1\u0ca8\u0cb0\u0cc1\u0ca4\u0ccd\u0caa\u0cbe\u0ca6\u0ca8\u0cc6\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cbf\u0c96\u0cb0\u0cb5\u0cbe\u0c97\u0cbf \u0cae\u0cbe\u0ca1\u0cac\u0cc7\u0c95\u0cc1 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0cae\u0cbe\u0ca1\u0cac\u0cbe\u0cb0\u0ca6\u0cc1\u0c85\u0cb5\u0cb9\u0cc7\u0cb3\u0ca8\u0c95\u0cbe\u0cb0\u0cbf \u0cb0\u0cc0\u0ca4\u0cbf\u0caf\u0cb2\u0ccd\u0cb2\u0cbf \u0c85\u0ca5\u0cb5\u0cbe \u0ca6\u0cbe\u0cb0\u0cbf\u0ca4\u0caa\u0ccd\u0caa\u0cbf\u0cb8\u0cc1\u0cb5 \u0cb8\u0c82\u0ca6\u0cb0\u0ccd\u0cad\u0ca6\u0cb2\u0ccd\u0cb2\u0cbf \u0cac\u0cb3\u0cb8\u0cb2\u0cbe\u0c97\u0cbf\u0ca6\u0cc6. \u0cb5\u0cbf\u0cb7\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0ccd\u0cb0\u0c95\u0c9f\u0cbf\u0cb8\u0cc1\u0cb5\u0cbe\u0c97 \u0c85\u0ca5\u0cb5\u0cbe \u0c87\u0ca4\u0cb0\u0cb0\u0cbf\u0c97\u0cc6 \u0ca8\u0cc0\u0ca1\u0cc1\u0cb5\u0cbe\u0c97, \u0cae\u0cc2\u0cb2\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0ccd\u0cb0\u0cae\u0cc1\u0c96\u0cb5\u0cbe\u0c97\u0cbf \u0c92\u0caa\u0ccd\u0caa\u0cbf\u0c95\u0cca\u0cb3\u0ccd\u0cb3\u0cac\u0cc7\u0c95\u0cc1. \u0c86\u0ca6\u0cbe\u0c97\u0ccd\u0caf\u0cc2, \u0c88 \u0cb5\u0cbf\u0cb7\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0cc1\u0ca8\u0cb0\u0cc1\u0ca4\u0ccd\u0caa\u0cbe\u0ca6\u0cbf\u0cb8\u0cb2\u0cc1 \u0c85\u0ca8\u0cc1\u0cae\u0ca4\u0cbf\u0caf\u0ca8\u0ccd\u0ca8\u0cc1 \u0cae\u0cc2\u0cb0\u0ca8\u0cc7 \u0cb5\u0ccd\u0caf\u0c95\u0ccd\u0ca4\u0cbf\u0caf \u0cb9\u0c95\u0ccd\u0c95\u0cc1\u0cb8\u0ccd\u0cb5\u0cbe\u0cae\u0ccd\u0caf \u0c8e\u0c82\u0ca6\u0cc1 \u0c97\u0cc1\u0cb0\u0cc1\u0ca4\u0cbf\u0cb8\u0cb2\u0cbe\u0ca6 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cb5\u0cbf\u0cb7\u0caf\u0c95\u0ccd\u0c95\u0cc6 (\u0cac\u0cb3\u0c95\u0cc6\u0ca6\u0cbe\u0cb0\u0cb0\u0cc1 \u0cb8\u0cb2\u0ccd\u0cb2\u0cbf\u0cb8\u0cbf\u0ca6 \u0cb5\u0cbf\u0cb7\u0caf) \u0cb5\u0cbf\u0cb8\u0ccd\u0ca4\u0cb0\u0cbf\u0cb8\u0cac\u0cbe\u0cb0\u0ca6\u0cc1. \u0c85\u0c82\u0ca4\u0cb9 \u0cb5\u0cbf\u0cb7\u0caf\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0caa\u0cc1\u0ca8\u0cb0\u0cc1\u0ca4\u0ccd\u0caa\u0cbe\u0ca6\u0cbf\u0cb8\u0cb2\u0cc1 \u0c85\u0ca7\u0cbf\u0c95\u0cbe\u0cb0\u0cb5\u0ca8\u0ccd\u0ca8\u0cc1 \u0cb8\u0c82\u0cac\u0c82\u0ca7\u0caa\u0c9f\u0ccd\u0c9f \u0cb9\u0c95\u0ccd\u0c95\u0cc1\u0cb8\u0ccd\u0cb5\u0cbe\u0cae\u0ccd\u0caf \u0cb9\u0cca\u0c82\u0ca6\u0cbf\u0cb0\u0cc1\u0cb5\u0cb5\u0cb0\u0cbf\u0c82\u0ca6 \u0caa\u0ca1\u0cc6\u0caf\u0cac\u0cc7\u0c95\u0cc1.","Hyperlink":"\u0cb9\u0cc8\u0caa\u0cb0\u0ccd\u200c\u0cb2\u0cbf\u0c82\u0c95\u0ccd \u0ca8\u0cc0\u0ca4\u0cbf","hyperLinkPSub1":"\u0cac\u0cbe\u0cb9\u0ccd\u0caf \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0c97\u0cb3\u0cc1/\u0caa\u0ccb\u0cb0\u0ccd\u0c9f\u0cb2\u0ccd\u200c\u0c97\u0cb3\u0cbf\u0c97\u0cc6 \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0c97\u0cb3\u0cc1","hyperLinkPSub2":"\u0c87\u0ca4\u0cb0 \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0c97\u0cb3\u0cc1/\u0caa\u0ccb\u0cb0\u0ccd\u0c9f\u0cb2\u0ccd\u200c\u0c97\u0cb3\u0cbf\u0c82\u0ca6 \u0caa\u0ccd\u0caf\u0cbe\u0cb0\u0cbf\u0c9a\u0cc7\u0c97\u0cc6 \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0c97\u0cb3\u0cc1","HyperlinkTextLink":"\u0cac\u0cbe\u0cb9\u0ccd\u0caf \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0c97\u0cb3\u0cc1/\u0caa\u0ccb\u0cb0\u0ccd\u0c9f\u0cb2\u0ccd\u200c\u0c97\u0cb3\u0cbf\u0c97\u0cc6 \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0c97\u0cb3\u0cc1","HyperlinkText":"\u0caa\u0cb0\u0cbf\u0c9a\u0cc7\u0caf \u0c95\u0cc6\u0cb2\u0cb5\u0cc1 \u0cb8\u0ccd\u0ca5\u0cb3\u0c97\u0cb3\u0cb2\u0ccd\u0cb2\u0cbf, \u0ca8\u0cc0\u0cb5\u0cc1 \u0c87\u0ca4\u0cb0 \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0c97\u0cb3\u0cc1/\u0caa\u0ccb\u0cb0\u0ccd\u0c9f\u0cb2\u0ccd\u200c\u0c97\u0cb3\u0cbf\u0c97\u0cc6 \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0c95\u0cbe\u0ca3\u0cac\u0cb9\u0cc1\u0ca6\u0cc1. \u0c88 \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cbf\u0cae\u0ccd\u0cae \u0c85\u0ca8\u0cc1\u0c95\u0cc2\u0cb2\u0c95\u0ccd\u0c95\u0cbe\u0c97\u0cbf \u0c87\u0cb0\u0cbf\u0cb8\u0cb2\u0cbe\u0c97\u0cbf\u0ca6\u0cc6. \u0cb2\u0cbf\u0c82\u0c95\u0ccd \u0cae\u0cbe\u0ca1\u0cb2\u0cbe\u0ca6 \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0c97\u0cb3\u0cc1/\u0cb8\u0cc7\u0cb5\u0cc6\u0c97\u0cb3 \u0cb5\u0cbf\u0cb7\u0caf\u0c97\u0cb3\u0cbf\u0c97\u0cc6 \u0caa\u0ccd\u0caf\u0cbe\u0cb0\u0cbf\u0c9a\u0cc7 \u0c9c\u0cb5\u0cbe\u0cac\u0ccd\u0ca6\u0cbe\u0cb0\u0ca8\u0cbe\u0c97\u0cbf\u0cb0\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0c85\u0cb5\u0cc1\u0c97\u0cb3\u0cb2\u0ccd\u0cb2\u0cbf \u0cb5\u0ccd\u0caf\u0c95\u0ccd\u0ca4\u0caa\u0ca1\u0cbf\u0cb8\u0cbf\u0ca6 \u0c85\u0cad\u0cbf\u0caa\u0ccd\u0cb0\u0cbe\u0caf\u0c97\u0cb3\u0ca8\u0ccd\u0ca8\u0cc1 \u0c85\u0c97\u0ca4\u0ccd\u0caf\u0cb5\u0cbe\u0c97\u0cbf \u0c85\u0ca8\u0cc1\u0cae\u0ccb\u0ca6\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2. \u0c88 \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0ca8\u0cb2\u0ccd\u0cb2\u0cbf \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0ca8 \u0c89\u0caa\u0cb8\u0ccd\u0ca5\u0cbf\u0ca4\u0cbf \u0c85\u0ca5\u0cb5\u0cbe \u0c85\u0ca6\u0cb0 \u0caa\u0c9f\u0ccd\u0c9f\u0cbf\u0caf\u0cc1 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0cb0\u0cc0\u0ca4\u0cbf\u0caf \u0c85\u0ca8\u0cc1\u0cae\u0ccb\u0ca6\u0ca8\u0cc6 \u0c8e\u0c82\u0ca6\u0cc1 \u0cad\u0cbe\u0cb5\u0cbf\u0cb8\u0cac\u0cbe\u0cb0\u0ca6\u0cc1. \u0c88 \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0c97\u0cb3\u0cc1 \u0c8e\u0cb2\u0ccd\u0cb2\u0cbe \u0cb8\u0cae\u0caf\u0ca6\u0cb2\u0ccd\u0cb2\u0cc2 \u0c95\u0cbe\u0cb0\u0ccd\u0caf\u0ca8\u0cbf\u0cb0\u0ccd\u0cb5\u0cb9\u0cbf\u0cb8\u0cc1\u0ca4\u0ccd\u0ca4\u0cb5\u0cc6 \u0c8e\u0c82\u0ca6\u0cc1 \u0ca8\u0cbe\u0cb5\u0cc1 \u0c96\u0cbe\u0ca4\u0cb0\u0cbf\u0caa\u0ca1\u0cbf\u0cb8\u0cc1\u0cb5\u0cc1\u0ca6\u0cbf\u0cb2\u0ccd\u0cb2 \u0cae\u0ca4\u0ccd\u0ca4\u0cc1 \u0cb2\u0cbf\u0c82\u0c95\u0ccd \u0cae\u0cbe\u0ca1\u0cb2\u0cbe\u0ca6 \u0c97\u0cae\u0ccd\u0caf\u0cb8\u0ccd\u0ca5\u0cbe\u0ca8\u0c97\u0cb3 \u0cb2\u0cad\u0ccd\u0caf\u0ca4\u0cc6\u0caf \u0cae\u0cc7\u0cb2\u0cc6 \u0ca8\u0cae\u0c97\u0cc6 \u0caf\u0cbe\u0cb5\u0cc1\u0ca6\u0cc7 \u0ca8\u0cbf\u0caf\u0c82\u0ca4\u0ccd\u0cb0\u0ca3\u0cb5\u0cbf\u0cb2\u0ccd\u0cb2.","linkToParichay":"\u0c87\u0ca4\u0cb0 \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0c97\u0cb3\u0cc1/\u0caa\u0ccb\u0cb0\u0ccd\u0c9f\u0cb2\u0ccd\u200c\u0c97\u0cb3\u0cbf\u0c82\u0ca6 Parichay \u0c97\u0cc6 \u0cb2\u0cbf\u0c82\u0c95\u0ccd\u200c\u0c97\u0cb3\u0cc1","linkToParichayText":"\u0c88 \u0cb5\u0cc6\u0cac\u0ccd\u200c\u0cb8\u0cc8\u0c9f\u0ccd\u200c\u0ca8\u0cb2\u0ccd\u0cb2\u0cbf \u0cb9\u0ccb\u0cb8\u0ccd\u0c9f\u0ccd \u0cae\u0cbe\u0ca1\u0cb2\u0cbe\u0ca6 \u0cae\u0cbe\u0cb9\u0cbf\u0ca4\u0cbf\u0c97\u0cc6 \u0ca8\u0cc0\u0cb5\u0cc1 \u0ca8\u0cc7\u0cb0\u0cb5\u0cbe\u0c97\u0cbf \u0cb2\u0cbf\u0c82\u0c95\u0ccd \u0cae\u0cbe\u0ca1\u0cc1\u0cb5\u0cc1\u0ca6\u0ca8\u0ccd\u0ca8\u0cc1 \u0ca8\u0cbe\u0cb5\u0cc1 \u0c86\u0c95\u0ccd\u0cb7\u0cc7\u0caa\u0cbf\u0