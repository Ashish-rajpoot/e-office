u0930 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964 \u0906\u092a \u090f\u0928\u0906\u0908\u0938\u0940 \u0915\u0940 \u092a\u0942\u0930\u094d\u0935 \u0932\u093f\u0916\u093f\u0924 \u0905\u0928\u0941\u092e\u0924\u093f \u0915\u0947 \u092c\u093f\u0928\u093e \u092a\u0930\u093f\u091a\u092f \u0914\u0930 \u0907\u0938\u0915\u0940 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u0915\u0940 \u0928\u093f\u0917\u0930\u093e\u0928\u0940 \u092f\u093e \u092a\u094d\u0930\u0924\u093f\u0932\u093f\u092a\u093f \u092c\u0928\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0915\u093f\u0938\u0940 \u0930\u094b\u092c\u094b\u091f, \u0938\u094d\u092a\u093e\u0907\u0921\u0930, \u0905\u0928\u094d\u092f \u0938\u094d\u0935\u091a\u093e\u0932\u093f\u0924 \u0938\u0949\u092b\u093c\u094d\u091f\u0935\u0947\u092f\u0930 \u092f\u093e \u0921\u093f\u0935\u093e\u0907\u0938 \u092f\u093e \u092e\u0948\u0928\u094d\u092f\u0941\u0905\u0932 \u092a\u094d\u0930\u0915\u094d\u0930\u093f\u092f\u093e \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0928\u0939\u0940\u0902 \u0915\u0930\u0947\u0902\u0917\u0947\u0964 \u0906\u092a \u0909\u092a\u092f\u094b\u0917 \u0915\u0940 \u0936\u0930\u094d\u0924\u094b\u0902 \u0915\u0940 \u0915\u0949\u092a\u0940\u0930\u093e\u0907\u091f \u0928\u0940\u0924\u093f \u0926\u094d\u0935\u093e\u0930\u093e \u0905\u0928\u0941\u092e\u0924 \u0938\u0940\u092e\u093e \u0915\u094b \u091b\u094b\u0921\u093c\u0915\u0930, \u092a\u0930\u093f\u091a\u092f \u0915\u0947 \u0938\u092d\u0940 \u092f\u093e \u0915\u093f\u0938\u0940 \u092d\u0940 \u0939\u093f\u0938\u094d\u0938\u0947 \u0915\u094b \u0935\u094d\u092f\u093e\u0935\u0938\u093e\u092f\u093f\u0915, \u0917\u0948\u0930-\u0932\u093e\u092d\u0915\u093e\u0930\u0940 \u092f\u093e \u0938\u093e\u0930\u094d\u0935\u091c\u0928\u093f\u0915 \u0909\u0926\u094d\u0926\u0947\u0936\u094d\u092f\u094b\u0902 \u0915\u0947 \u0932\u093f\u090f \u0915\u0949\u092a\u0940, \u0938\u0902\u0936\u094b\u0927\u093f\u0924, \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u092a\u093e\u0926\u0928, \u092a\u0941\u0928\u0930\u094d\u092a\u094d\u0930\u0915\u093e\u0936\u093f\u0924, \u0935\u093f\u0924\u0930\u093f\u0924, \u092a\u094d\u0930\u0926\u0930\u094d\u0936\u093f\u0924 \u092f\u093e \u092a\u094d\u0930\u0938\u093e\u0930\u093f\u0924 \u0928\u0939\u0940\u0902 \u0915\u0930\u0947\u0902\u0917\u0947\u0964 \u092a\u0930\u093f\u091a\u092f \u0915\u093e \u0915\u094b\u0908 \u092d\u0940 \u0905\u0928\u0927\u093f\u0915\u0943\u0924 \u0909\u092a\u092f\u094b\u0917\u0964","userResponsibility":"\u0909\u092a\u092f\u094b\u0917\u0915\u0930\u094d\u0924\u093e \u0915\u0940 \u091c\u093f\u092e\u094d\u092e\u0947\u0926\u093e\u0930\u0940","userResponsibilityText":"\u090f\u0915 \u091c\u093f\u092e\u094d\u092e\u0947\u0926\u093e\u0930 \u0909\u092a\u092f\u094b\u0917\u0915\u0930\u094d\u0924\u093e \u0915\u0947 \u0930\u0942\u092a \u092e\u0947\u0902, \u0906\u092a\u0915\u094b \u092f\u0939 \u0915\u0930\u0928\u093e \u0939\u094b\u0917\u093e:","userResponsibilityLi1":"\u0938\u0947\u0935\u093e \u0924\u0915 \u092a\u0939\u0941\u0901\u091a\u0928\u0947 \u092f\u093e \u0909\u0938\u0915\u0940 \u0924\u0932\u093e\u0936 \u0915\u0930\u0928\u0947 \u0935\u093e\u0932\u093e \u090f\u0915 \u0938\u094d\u0935\u093e\u092d\u093e\u0935\u093f\u0915 \u0935\u094d\u092f\u0915\u094d\u0924\u093f \u092c\u0928\u0947\u0902.","userResponsibilityLi2":"\u092a\u0930\u093f\u091a\u092f \u0938\u0947\u0935\u093e \u0916\u093e\u0924\u093e;","userResponsibilityLi11":"\u0915\u093f\u0938\u0940 \u0905\u0928\u094d\u092f \u0935\u094d\u092f\u0915\u094d\u0924\u093f \u0915\u094b \u0905\u092a\u0928\u093e \u0909\u092a\u092f\u094b\u0917\u0915\u0930\u094d\u0924\u093e \u0928\u093e\u092e \u0914\u0930 \u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u092f\u093e \u0915\u093f\u0938\u0940 \u0915\u094d\u0930\u0947\u0921\u0947\u0902\u0936\u093f\u092f\u0932 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0928\u0947 \u0915\u0940 \u0905\u0928\u0941\u092e\u0924\u093f \u0928 \u0926\u0947\u0902; \u0905\u092a\u0928\u0947 \u0916\u093e\u0924\u0947 \u0915\u093e \u0909\u092a\u092f\u094b\u0917\u0915\u0930\u094d\u0924\u093e \u0928\u093e\u092e, \u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u092f\u093e \u0915\u094b\u0908 \u092d\u0940 \u0915\u094d\u0930\u0947\u0921\u0947\u0902\u0936\u093f\u092f\u0932 \u0939\u0930 \u0938\u092e\u092f \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u0914\u0930 \u0917\u094b\u092a\u0928\u0940\u092f \u0930\u0916\u0947\u0902 \u0914\u0930 \u0906\u092a\u0915\u094b \u0915\u093f\u0938\u0940 \u0914\u0930 \u0915\u0947 \u0938\u093e\u092e\u0928\u0947 \u092a\u094d\u0930\u0915\u091f \u0928 \u0915\u0930\u0947\u0902;","userResponsibilityLi12":"\u092f\u0926\u093f \u0906\u092a\u0915\u094b \u0938\u0902\u0926\u0947\u0939 \u0939\u0948 \u0915\u093f \u0906\u092a\u0915\u0947 \u092a\u0930\u093f\u091a\u092f \u0916\u093e\u0924\u0947 \u0915\u0940 \u0938\u0941\u0930\u0915\u094d\u0937\u093e \u0938\u0947 \u0938\u092e\u091d\u094c\u0924\u093e \u0915\u093f\u092f\u093e \u0917\u092f\u093e \u0939\u0948, \u0924\u094b \u0924\u0941\u0930\u0902\u0924 \u092a\u0930\u093f\u091a\u092f \u0939\u0947\u0932\u094d\u092a\u0921\u0947\u0938\u094d\u0915 \u092a\u0930 \u0930\u093f\u092a\u094b\u0930\u094d\u091f \u0915\u0930\u0947\u0902, \u0909\u0926\u093e\u0939\u0930\u0923 \u0915\u0947 \u0932\u093f\u090f: \u0906\u092a\u0915\u093e \u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u092f\u093e \u0909\u092a\u092f\u094b\u0917\u0915\u0930\u094d\u0924\u093e \u0928\u093e\u092e \u0916\u094b \u0917\u092f\u093e \u0939\u0948 \u092f\u093e \u091a\u094b\u0930\u0940 \u0939\u094b \u0917\u092f\u093e \u0939\u0948\u0964 \u0939\u092e\u0938\u0947 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u0947\u0902 \u092a\u0930 \u0909\u092a\u0932\u092c\u094d\u0927 \u0935\u093f\u0935\u0930\u0923 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0915\u0947 \u0939\u0947\u0932\u094d\u092a\u0921\u0947\u0938\u094d\u0915 \u0938\u0947 \u0938\u0902\u092a\u0930\u094d\u0915 \u0915\u0930\u0947\u0902;","userResponsibilityLi3":"\u092a\u0930\u093f\u091a\u092f \u092a\u0930 \u0935\u093f\u0935\u0930\u0923 \u0915\u0947\u0935\u0932 \u092a\u0930\u093f\u091a\u092f \u092a\u094b\u0930\u094d\u091f\u0932 \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0939\u0940 \u092a\u094d\u0930\u093e\u092a\u094d\u0924 \u0915\u093f\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948, \u0914\u0930 \u0915\u0947\u0935\u0932 \u0909\u092a\u092f\u094b\u0917\u0915\u0930\u094d\u0924\u093e \u0928\u093e\u092e \u0914\u0930 \u092a\u094d\u0930\u092e\u093e\u0923\u0940\u0915\u0930\u0923 \u0935\u093f\u0935\u0930\u0923 \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u093f\u092f\u093e \u091c\u093e \u0938\u0915\u0924\u093e \u0939\u0948 \u091c\u094b \u0906\u092a\u0915\u094b \u0935\u093f\u0936\u0947\u0937 \u0930\u0942\u092a \u0938\u0947 \u0906\u0935\u0902\u091f\u093f\u0924 \u0915\u093f\u092f\u093e \u0917\u092f\u093e \u0939\u0948\u0964","userResponsibilityLi4":"\u0906\u092a\u0915\u094b \u092a\u0930\u093f\u091a\u092f \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0915\u094b\u0908 \u092d\u0940 \u0917\u0948\u0930\u0915\u093e\u0928\u0942\u0928\u0940, \u092e\u093e\u0928\u0939\u093e\u0928\u093f\u0915\u093e\u0930\u0915, \u0905\u0936\u094d\u0932\u0940\u0932, \u0906\u092a\u0924\u094d\u0924\u093f\u091c\u0928\u0915 \u092f\u093e \u0928\u093f\u0902\u0926\u0928\u0940\u092f \u0938\u093e\u092e\u0917\u094d\u0930\u0940, \u092f\u093e \u0910\u0938\u0940 \u0915\u094b\u0908 \u092d\u0940 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u092a\u094d\u0930\u0938\u093e\u0930\u093f\u0924 \u0928\u0939\u0940\u0902 \u0915\u0930\u0928\u0940 \u091a\u093e\u0939\u093f\u090f \u091c\u094b \u0915\u093f\u0938\u0940 \u092d\u0940 \u0915\u093e\u0928\u0942\u0928 \u0915\u093e \u0909\u0932\u094d\u0932\u0902\u0918\u0928 \u0915\u0930\u0924\u0940 \u0939\u094b \u092f\u093e \u0906\u091a\u0930\u0923 \u0915\u094b \u092a\u094d\u0930\u094b\u0924\u094d\u0938\u093e\u0939\u093f\u0924 \u0915\u0930\u0924\u0940 \u0939\u094b\u0964","userResponsibilityLi5":"\u092f\u0926\u093f, \u0906\u092a\u0915\u0947 \u092a\u0930\u093f\u091a\u092f \u0916\u093e\u0924\u0947 \u092e\u0947\u0902, \u0906\u092a\u0938\u0947 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0915\u0939\u093e \u091c\u093e\u0924\u093e \u0939\u0948, \u0924\u094b \u0906\u092a\u0915\u0947 \u0926\u094d\u0935\u093e\u0930\u093e \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0940 \u0917\u0908 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u092a\u0942\u0930\u094d\u0923 \u0914\u0930 \u0938\u091f\u0940\u0915 \u0939\u094b\u0928\u0940 \u091a\u093e\u0939\u093f\u090f\u0964 \u0906\u092a \u0938\u094d\u0935\u0940\u0915\u093e\u0930 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0915\u093f \u092f\u0926\u093f \u0906\u092a \u0905\u0927\u0942\u0930\u0940, \u0917\u0932\u0924 \u092f\u093e \u0917\u0932\u0924 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u0915\u093f\u0938\u0940 \u0905\u0928\u0927\u093f\u0915\u0943\u0924 \u0915\u093e\u0930\u094d\u092f \u0915\u094b \u0915\u0930\u0928\u0947 (\u092f\u093e \u0915\u0930\u0928\u0947 \u0915\u093e \u092a\u094d\u0930\u092f\u093e\u0938) \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u092a\u0930\u093f\u091a\u092f \u0915\u093e \u0909\u092a\u092f\u094b\u0917 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u092f\u093e \u0905\u0928\u094d\u092f\u0925\u093e \u092a\u0930\u093f\u091a\u092f \u0915\u093e \u0926\u0941\u0930\u0941\u092a\u092f\u094b\u0917 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902 \u0924\u094b \u092f\u0939 \u0906\u092a\u0915\u0940 \u092a\u0930\u093f\u091a\u092f \u092a\u0939\u0941\u0902\u091a \u0915\u094b \u0928\u093f\u0932\u0902\u092c\u093f\u0924 \u092f\u093e \u0938\u092e\u093e\u092a\u094d\u0924 \u0915\u0930 \u0938\u0915\u0924\u093e \u0939\u0948\u0964","userResponsibilityLi6":"\u0917\u0932\u0924 \u092f\u093e \u092d\u094d\u0930\u093e\u092e\u0915 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u0926\u0947\u0928\u093e \u090f\u0915 \u0917\u0902\u092d\u0940\u0930 \u0905\u092a\u0930\u093e\u0927 \u0939\u0948\u0964 \u092a\u0930\u093f\u091a\u092f \u0915\u0947 \u092e\u093e\u0927\u094d\u092f\u092e \u0938\u0947 \u0905\u0927\u0942\u0930\u0940, \u0917\u0932\u0924 \u092f\u093e \u0917\u0932\u0924 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0928\u093e \u0909\u0938\u0940 \u0924\u0930\u0939 \u092e\u093e\u0928\u093e \u091c\u093e\u090f\u0917\u093e \u091c\u0948\u0938\u0947 \u0915\u093f\u0938\u0940 \u092b\u0949\u0930\u094d\u092e \u092a\u0930 \u092f\u093e \u0935\u094d\u092f\u0915\u094d\u0924\u093f\u0917\u0924 \u0930\u0942\u092a \u0938\u0947 \u0917\u0932\u0924 \u091c\u093e\u0928\u0915\u093e\u0930\u0940 \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0928\u093e \u0914\u0930 \u0907\u0938\u0915\u0947 \u092a\u0930\u093f\u0923\u093e\u092e\u0938\u094d\u0935\u0930\u0942\u092a \u0905\u092d\u093f\u092f\u094b\u091c\u0928 \u0914\u0930 \u0928\u093e\u0917\u0930\u093f\u0915 \u092f\u093e \u0906\u092a\u0930\u093e\u0927\u093f\u0915 \u0926\u0902\u0921 \u0939\u094b \u0938\u0915\u0924\u093e \u0939\u0948\u0964","userResponsibilityText2":"\u0907\u0938 \u0935\u0947\u092c\u0938\u093e\u0907\u091f/\u092a\u094b\u0930\u094d\u091f\u0932 \u092a\u0930 \u092a\u094d\u0930\u0926\u0930\u094d\u0936\u093f\u0924 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u0915\u094b \u090f\u0928\u0906\u0908\u0938\u0940 \u0915\u0940 \u0938\u094d\u092a\u0937\u094d\u091f \u0932\u093f\u0916\u093f\u0924 \u0905\u0928\u0941\u092e\u0924\u093f \u0915\u0947 \u092c\u093f\u0928\u093e \u0915\u0939\u0940\u0902 \u092d\u0940 \u092a\u0941\u0928: \u092a\u094d\u0930\u0938\u094d\u0924\u0941\u0924 \u0928\u0939\u0940\u0902 \u0915\u093f\u092f\u093e \u091c\u093e\u090f\u0917\u093e\u0964 \u0939\u093e\u0932\u093e\u0901\u0915\u093f, \u092f\u0926\u093f \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u0915\u094b \u0905\u0928\u0941\u092e\u0924\u093f \u0915\u0947 \u0938\u093e\u0925 \u092a\u0941\u0928: \u092a\u094d\u0930\u0938\u094d\u0924\u0