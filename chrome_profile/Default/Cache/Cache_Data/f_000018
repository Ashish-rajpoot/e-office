\u0923\u093e\u092e\u0940 \u0939\u093e\u0928\u0940 \u0915\u093f\u0902\u0935\u093e \u0928\u0941\u0915\u0938\u093e\u0928, \u0915\u093f\u0902\u0935\u093e \u0935\u093e\u092a\u0930\u093e\u092e\u0941\u0933\u0947 \u0909\u0926\u094d\u092d\u0935\u0932\u0947\u0932\u094d\u092f\u093e \u0915\u094b\u0923\u0924\u094d\u092f\u093e\u0939\u0940 \u0916\u0930\u094d\u091a, \u0928\u0941\u0915\u0938\u093e\u0928 \u0915\u093f\u0902\u0935\u093e \u0928\u0941\u0915\u0938\u093e\u0928\u093e\u0938\u0939, \u0915\u094b\u0923\u0924\u094d\u092f\u093e\u0939\u0940 \u0916\u0930\u094d\u091a\u093e\u0938\u093e\u0920\u0940, \u0924\u094b\u091f\u093e \u0915\u093f\u0902\u0935\u093e \u0928\u0941\u0915\u0938\u093e\u0928\u093e\u0938\u093e\u0920\u0940 \u091c\u092c\u093e\u092c\u0926\u093e\u0930 \u0905\u0938\u0923\u093e\u0930 \u0928\u093e\u0939\u0940 \u0921\u0947\u091f\u093e, \u092a\u0930\u093f\u091a\u092f\u093e\u091a\u094d\u092f\u093e \u0935\u093e\u092a\u0930\u093e\u0924\u0942\u0928 \u0909\u0926\u094d\u092d\u0935\u0932\u0947\u0932\u093e \u0915\u093f\u0902\u0935\u093e \u0924\u094d\u092f\u093e\u091a\u094d\u092f\u093e \u0938\u0902\u092c\u0902\u0927\u093e\u0924.","termsUseLi6":"\u092a\u0930\u093f\u091a\u092f \u0926\u094d\u0935\u093e\u0930\u0947 \u0911\u092b\u0930 \u0915\u0947\u0932\u0947\u0932\u0940 \u0938\u0947\u0935\u093e \u0915\u0947\u0935\u0933 \u0924\u0941\u092e\u091a\u094d\u092f\u093e \u0935\u0948\u092f\u0915\u094d\u0924\u093f\u0915 \u0935\u093e\u092a\u0930\u093e\u0938\u093e\u0920\u0940 \u0906\u0939\u0947 \u0906\u0923\u093f \u0935\u094d\u092f\u093e\u0935\u0938\u093e\u092f\u093f\u0915 \u0936\u094b\u0937\u0923\u093e\u0938\u093e\u0920\u0940 \u0928\u093e\u0939\u0940. \u0924\u0941\u092e\u094d\u0939\u0940 \u092a\u0930\u093f\u091a\u092f \u0915\u0921\u0942\u0928 \u0921\u093f\u0915\u0902\u092a\u093e\u0907\u0932, \u0930\u093f\u0935\u094d\u0939\u0930\u094d\u0938 \u0907\u0902\u091c\u093f\u0928\u093f\u092f\u0930, \u0921\u093f\u0938\u0938\u0947\u092e\u094d\u092c\u0932, \u092d\u093e\u0921\u094d\u092f\u093e\u0928\u0947, \u0932\u0940\u091c, \u0915\u0930\u094d\u091c, \u0935\u093f\u0915\u094d\u0930\u0940, \u0909\u092a\u092a\u0930\u0935\u093e\u0928\u093e \u0915\u093f\u0902\u0935\u093e \u0935\u094d\u092f\u0941\u0924\u094d\u092a\u0928\u094d\u0928 \u0915\u093e\u092e\u0947 \u0924\u092f\u093e\u0930 \u0915\u0930\u0942 \u0936\u0915\u0924 \u0928\u093e\u0939\u0940. \u0924\u0938\u0947\u091a \u0924\u0941\u092e\u094d\u0939\u0940 \u0972\u092a\u094d\u0932\u093f\u0915\u0947\u0936\u0928/\u0938\u093e\u0907\u091f \u0906\u0930\u094d\u0915\u093f\u091f\u0947\u0915\u094d\u091a\u0930 \u0928\u093f\u0930\u094d\u0927\u093e\u0930\u093f\u0924 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0915\u093f\u0902\u0935\u093e \u0935\u093e\u092a\u0930, \u0935\u0948\u092f\u0915\u094d\u0924\u093f\u0915 \u0913\u0933\u0916 \u0915\u093f\u0902\u0935\u093e \u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u094d\u092f\u093e\u0902\u092c\u0926\u094d\u0926\u0932 \u092e\u093e\u0939\u093f\u0924\u0940 \u0915\u093e\u0922\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0915\u094b\u0923\u0924\u0947\u0939\u0940 \u0928\u0947\u091f\u0935\u0930\u094d\u0915 \u092e\u0949\u0928\u093f\u091f\u0930\u093f\u0902\u0917 \u0915\u093f\u0902\u0935\u093e \u0936\u094b\u0927 \u0938\u0949\u092b\u094d\u091f\u0935\u0947\u0905\u0930 \u0935\u093e\u092a\u0930\u0942 \u0936\u0915\u0924 \u0928\u093e\u0939\u0940. NIC \u091a\u094d\u092f\u093e \u092a\u0942\u0930\u094d\u0935 \u0932\u0947\u0916\u0940 \u092a\u0930\u0935\u093e\u0928\u0917\u0940\u0936\u093f\u0935\u093e\u092f \u092a\u0930\u093f\u091a\u092f \u0906\u0923\u093f \u0924\u094d\u092f\u093e\u0924\u0940\u0932 \u0938\u093e\u092e\u0917\u094d\u0930\u0940\u091a\u0947 \u0928\u093f\u0930\u0940\u0915\u094d\u0937\u0923 \u0915\u093f\u0902\u0935\u093e \u0915\u0949\u092a\u0940 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0924\u0941\u092e\u094d\u0939\u0940 \u0915\u094b\u0923\u0924\u093e\u0939\u0940 \u0930\u094b\u092c\u094b\u091f, \u0938\u094d\u092a\u093e\u092f\u0921\u0930, \u0907\u0924\u0930 \u0938\u094d\u0935\u092f\u0902\u091a\u0932\u093f\u0924 \u0938\u0949\u092b\u094d\u091f\u0935\u0947\u0905\u0930 \u0915\u093f\u0902\u0935\u093e \u0921\u093f\u0935\u094d\u0939\u093e\u0907\u0938 \u0915\u093f\u0902\u0935\u093e \u092e\u0945\u0928\u094d\u092f\u0941\u0905\u0932 \u092a\u094d\u0930\u0915\u094d\u0930\u093f\u092f\u093e \u0935\u093e\u092a\u0930\u0923\u093e\u0930 \u0928\u093e\u0939\u0940. \u092f\u093e \u0935\u093e\u092a\u0930\u093e\u091a\u094d\u092f\u093e \u0905\u091f\u0940\u0902\u091a\u094d\u092f\u093e \u0915\u0949\u092a\u0940\u0930\u093e\u0907\u091f \u0927\u094b\u0930\u0923\u093e\u0928\u0947 \u092a\u0930\u0935\u093e\u0928\u0917\u0940 \u0926\u093f\u0932\u0947\u0932\u094d\u092f\u093e \u092e\u0930\u094d\u092f\u093e\u0926\u0947\u0936\u093f\u0935\u093e\u092f \u0924\u0941\u092e\u094d\u0939\u0940 \u092a\u0930\u093f\u091a\u092f\u093e\u091a\u093e \u0938\u0930\u094d\u0935 \u0915\u093f\u0902\u0935\u093e \u0915\u094b\u0923\u0924\u093e\u0939\u0940 \u092d\u093e\u0917 \u0935\u094d\u092f\u093e\u0935\u0938\u093e\u092f\u093f\u0915, \u0928\u093e-\u0928\u092b\u093e \u0915\u093f\u0902\u0935\u093e \u0938\u093e\u0930\u094d\u0935\u091c\u0928\u093f\u0915 \u0939\u0947\u0924\u0942\u0902\u0938\u093e\u0920\u0940 \u0915\u0949\u092a\u0940, \u0938\u0941\u0927\u093e\u0930\u093f\u0924, \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u092a\u093e\u0926\u093f\u0924, \u092a\u0941\u0928\u0930\u094d\u092a\u094d\u0930\u0915\u093e\u0936\u093f\u0924, \u0935\u093f\u0924\u0930\u0923, \u092a\u094d\u0930\u0926\u0930\u094d\u0936\u0928 \u0915\u093f\u0902\u0935\u093e \u092a\u094d\u0930\u0938\u093e\u0930\u093f\u0924 \u0915\u0930\u0923\u093e\u0930 \u0928\u093e\u0939\u0940. \u092a\u0930\u093f\u091a\u092f \u091a\u093e \u0915\u094b\u0923\u0924\u093e\u0939\u0940 \u0905\u0928\u0927\u093f\u0915\u0943\u0924 \u0935\u093e\u092a\u0930.","userResponsibility":"\u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u094d\u092f\u093e\u091a\u0940 \u091c\u092c\u093e\u092c\u0926\u093e\u0930\u0940","userResponsibilityText":"\u090f\u0915 \u091c\u092c\u093e\u092c\u0926\u093e\u0930 \u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u093e \u092e\u094d\u0939\u0923\u0942\u0928, \u0924\u0941\u092e\u094d\u0939\u0940 \u0939\u0947 \u0915\u0930\u0923\u0947 \u0906\u0935\u0936\u094d\u092f\u0915 \u0906\u0939\u0947:","userResponsibilityLi1":"\u0938\u0947\u0935\u0947\u092e\u0927\u094d\u092f\u0947 \u092a\u094d\u0930\u0935\u0947\u0936 \u0915\u0930\u0923\u093e\u0930\u0940 \u0915\u093f\u0902\u0935\u093e \u0905\u0945\u0915\u094d\u0938\u0947\u0938 \u0915\u0930\u0923\u094d\u092f\u093e\u091a\u093e \u092a\u094d\u0930\u092f\u0924\u094d\u0928 \u0915\u0930\u0923\u093e\u0930\u0940 \u0928\u0948\u0938\u0930\u094d\u0917\u093f\u0915 \u0935\u094d\u092f\u0915\u094d\u0924\u0940 \u0935\u094d\u0939\u093e.","userResponsibilityLi2":"\u092a\u0930\u093f\u091a\u092f \u0938\u0947\u0935\u093e \u0916\u093e\u0924\u0947;","userResponsibilityLi11":"\u0924\u0941\u092e\u091a\u0947 \u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u093e\u0928\u093e\u0935 \u0906\u0923\u093f \u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u0915\u093f\u0902\u0935\u093e \u0915\u094b\u0923\u0924\u0947\u0939\u0940 \u0915\u094d\u0930\u0947\u0921\u0947\u0928\u094d\u0936\u093f\u092f\u0932\u094d\u0938 \u0935\u093e\u092a\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0907\u0924\u0930 \u0915\u094b\u0923\u0924\u094d\u092f\u093e\u0939\u0940 \u0935\u094d\u092f\u0915\u094d\u0924\u0940\u0938 \u092a\u0930\u0935\u093e\u0928\u0917\u0940 \u0926\u0947\u090a \u0928\u0915\u093e; \u0924\u0941\u092e\u091a\u0947 \u0916\u093e\u0924\u0947 \u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u093e\u0928\u093e\u0935, \u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u0915\u093f\u0902\u0935\u093e \u0915\u094b\u0923\u0924\u0940\u0939\u0940 \u0915\u094d\u0930\u0947\u0921\u0947\u0928\u094d\u0936\u093f\u092f\u0932\u094d\u0938 \u0928\u0947\u0939\u092e\u0940 \u0938\u0941\u0930\u0915\u094d\u0937\u093f\u0924 \u0906\u0923\u093f \u0917\u094b\u092a\u0928\u0940\u092f \u0920\u0947\u0935\u093e \u0906\u0923\u093f \u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u0907\u0924\u0930 \u0915\u094b\u0923\u093e\u0938\u0939\u0940 \u0909\u0918\u0921 \u0915\u0930\u0942 \u0928\u0915\u093e;","userResponsibilityLi12":"\u0924\u0941\u092e\u091a\u094d\u092f\u093e \u092a\u0930\u093f\u091a\u092f \u0916\u093e\u0924\u094d\u092f\u093e\u091a\u094d\u092f\u093e \u0938\u0941\u0930\u0915\u094d\u0937\u0947\u0936\u0940 \u0924\u0921\u091c\u094b\u0921 \u0915\u0947\u0932\u0940 \u0917\u0947\u0932\u0940 \u0905\u0938\u0932\u094d\u092f\u093e\u091a\u0940 \u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u0936\u0902\u0915\u093e \u0905\u0938\u0932\u094d\u092f\u093e\u0938 \u0924\u093e\u092c\u0921\u0924\u094b\u092c \u092a\u0930\u093f\u091a\u092f \u0939\u0947\u0932\u094d\u092a\u0921\u0947\u0938\u094d\u0915\u0932\u093e \u0915\u0933\u0935\u093e. \u0909\u0926\u093e. \u0924\u0941\u092e\u091a\u093e \u092a\u093e\u0938\u0935\u0930\u094d\u0921 \u0915\u093f\u0902\u0935\u093e \u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u093e\u0928\u093e\u0935 \u0939\u0930\u0935\u0932\u0947 \u0915\u093f\u0902\u0935\u093e \u091a\u094b\u0930\u0940\u0932\u093e \u0917\u0947\u0932\u0947. \u0906\u092e\u091a\u094d\u092f\u093e\u0936\u0940 \u0938\u0902\u092a\u0930\u094d\u0915 \u0938\u093e\u0927\u093e \u092f\u0947\u0925\u0947 \u0909\u092a\u0932\u092c\u094d\u0927 \u0924\u092a\u0936\u0940\u0932 \u0935\u093e\u092a\u0930\u0942\u0928 \u0939\u0947\u0932\u094d\u092a\u0921\u0947\u0938\u094d\u0915\u0936\u0940 \u0938\u0902\u092a\u0930\u094d\u0915 \u0938\u093e\u0927\u093e;","userResponsibilityLi3":"Parichay \u0935\u0930\u0940\u0932 \u0924\u092a\u0936\u0940\u0932 \u0915\u0947\u0935\u0933 \u092a\u0930\u093f\u091a\u092f \u092a\u094b\u0930\u094d\u091f\u0932\u0926\u094d\u0935\u093e\u0930\u0947 \u0906\u0923\u093f \u0915\u0947\u0935\u0933 \u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u093e\u0928\u093e\u0935 \u0906\u0923\u093f \u092a\u094d\u0930\u092e\u093e\u0923\u0940\u0915\u0930\u0923 \u0924\u092a\u0936\u0940\u0932 \u0935\u093e\u092a\u0930\u0942\u0928 \u092a\u094d\u0930\u0935\u0947\u0936 \u0915\u0947\u0932\u093e \u091c\u093e\u090a \u0936\u0915\u0924\u094b \u091c\u0947 \u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u0935\u093f\u0936\u0947\u0937\u0924: \u0935\u093e\u091f\u092a \u0915\u0947\u0932\u0947 \u0917\u0947\u0932\u0947 \u0906\u0939\u0947\u0924.","userResponsibilityLi4":"\u0924\u0941\u092e\u094d\u0939\u0940 \u0915\u094b\u0923\u0924\u0940\u0939\u0940 \u092c\u0947\u0915\u093e\u092f\u0926\u0947\u0936\u0940\u0930, \u092c\u0926\u0928\u093e\u092e\u0940\u0915\u093e\u0930\u0915, \u0905\u0936\u094d\u0932\u0940\u0932, \u0906\u0915\u094d\u0937\u0947\u092a\u093e\u0930\u094d\u0939 \u0915\u093f\u0902\u0935\u093e \u0928\u093f\u0902\u0926\u0928\u0940\u092f \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u0915\u093f\u0902\u0935\u093e \u0915\u094b\u0923\u0924\u094d\u092f\u093e\u0939\u0940 \u0915\u093e\u092f\u0926\u094d\u092f\u093e\u091a\u0947 \u0909\u0932\u094d\u0932\u0902\u0918\u0928 \u0915\u0930\u0923\u093e\u0930\u0940 \u0935\u0930\u094d\u0924\u0923\u0942\u0915 \u0924\u092f\u093e\u0930 \u0915\u0930\u0923\u093e\u0930\u0940 \u0915\u093f\u0902\u0935\u093e \u092a\u094d\u0930\u094b\u0924\u094d\u0938\u093e\u0939\u0928 \u0926\u0947\u0923\u093e\u0930\u0940 \u0915\u094b\u0923\u0924\u0940\u0939\u0940 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u092a\u0930\u093f\u091a\u092f\u093e\u0926\u094d\u0935\u093e\u0930\u0947 \u092a\u094d\u0930\u0938\u093e\u0930\u093f\u0924 \u0915\u0930\u0942 \u0928\u092f\u0947.","userResponsibilityLi5":"\u0924\u0941\u092e\u091a\u094d\u092f\u093e \u092a\u0930\u093f\u091a\u092f \u0916\u093e\u0924\u094d\u092f\u093e\u092e\u0927\u094d\u092f\u0947, \u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u092e\u093e\u0939\u093f\u0924\u0940 \u0926\u0947\u0923\u094d\u092f\u093e\u0938 \u0938\u093e\u0902\u0917\u093f\u0924\u0932\u0947 \u0905\u0938\u0932\u094d\u092f\u093e\u0938, \u0924\u0941\u092e\u094d\u0939\u0940 \u092a\u0941\u0930\u0935\u0932\u0947\u0932\u0940 \u092e\u093e\u0939\u093f\u0924\u0940 \u092a\u0942\u0930\u094d\u0923 \u0906\u0923\u093f \u0905\u091a\u0942\u0915 \u0905\u0938\u0923\u0947 \u0906\u0935\u0936\u094d\u092f\u0915 \u0906\u0939\u0947. \u0924\u0941\u092e\u094d\u0939\u0940 \u0915\u092c\u0942\u0932 \u0915\u0930\u0924\u093e \u0915\u0940 \u0924\u0941\u092e\u094d\u0939\u0940 \u0905\u092a\u0942\u0930\u094d\u0923, \u091a\u0941\u0915\u0940\u091a\u0940 \u0915\u093f\u0902\u0935\u093e \u0916\u094b\u091f\u0940 \u092e\u093e\u0939\u093f\u0924\u0940 \u092a\u0941\u0930\u0935\u0932\u094d\u092f\u093e\u0938, \u0905\u0928\u0927\u093f\u0915\u0943\u0924 \u0915\u0943\u0924\u0940 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 (\u0915\u093f\u0902\u0935\u093e \u0915\u0930\u0923\u094d\u092f\u093e\u091a\u093e \u092a\u094d\u0930\u092f\u0924\u094d\u0928 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940) \u092a\u0930\u093f\u091a\u092f \u0935\u093e\u092a\u0930\u0932\u094d\u092f\u093e\u0938 \u0915\u093f\u0902\u0935\u093e \u0905\u0928\u094d\u092f\u0925\u093e \u092a\u0930\u093f\u091a\u092f\u093e\u091a\u093e \u0917\u0948\u0930\u0935\u093e\u092a\u0930 \u0915\u0947\u0932\u094d\u092f\u093e\u0938 \u0924\u0947 \u0924\u0941\u092e\u091a\u093e\xa0\u092a\u0930\u093f\u091a\u092f \u092a\u094d\u0930\u0935\u0947\u0936 \u0928\u093f\u0932\u0902\u092c\u093f\u0924 \u0915\u093f\u0902\u0935\u093e \u0938\u092e\u093e\u092a\u094d\u0924 \u0915\u0930\u0942 \u0936\u0915\u0924\u0947.","userResponsibilityLi6":"\u0916\u094b\u091f\u0940 \u0915\u093f\u0902\u0935\u093e \u0926\u093f\u0936\u093e\u092d\u0942\u0932 \u0915\u0930\u0923\u093e\u0930\u0940 \u092e\u093e\u0939\u093f\u0924\u0940 \u0926\u0947\u0923\u0947 \u0939\u093e \u0917\u0902\u092d\u0940\u0930 \u0917\u0941\u0928\u094d\u0939\u093e \u0906\u0939\u0947. \u092a\u0930\u093f\u091a\u092f \u0926\u094d\u0935\u093e\u0930\u0947 \u0905\u092a\u0942\u0930\u094d\u0923, \u091a\u0941\u0915\u0940\u091a\u0940 \u0915\u093f\u0902\u0935\u093e \u0916\u094b\u091f\u0940 \u092e\u093e\u0939\u093f\u0924\u0940 \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0923\u0947 \u0939\u0947 \u090f\u0916\u093e\u0926\u094d\u092f\u093e \u092b\u0949\u0930\u094d\u092e\u0935\u0930 \u0915\u093f\u0902\u0935\u093e \u0935\u0948\u092f\u0915\u094d\u0924\u093f\u0915\u0930\u093f\u0924\u094d\u092f\u093e \u091a\u0941\u0915\u0940\u091a\u0940 \u092e\u093e\u0939\u093f\u0924\u0940 \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0930\u0916\u0947\u091a \u092e\u093e\u0928\u0932\u0947 \u091c\u093e\u0908\u0932 \u0906\u0923\u093f \u0924\u094d\u092f\u093e\u091a\u093e \u092a\u0930\u093f\u0923\u093e\u092e \u0916\u091f\u0932\u093e \u0906\u0923\u093f \u0926\u093f\u0935\u093e\u0923\u0940 \u0915\u093f\u0902\u0935\u093e \u092b\u094c\u091c\u0926\u093e\u0930\u0940 \u0926\u0902\u0921 \u0939\u094b\u090a \u0936\u0915\u0924\u094b.","userResponsibilityText2":"NIC \u091a\u094d\u092f\u093e \u0938\u094d\u092a\u0937\u094d\u091f \u0932\u0947\u0916\u0940 \u092a\u0930\u0935\u093e\u0928\u0917\u0940\u0936\u093f\u0935\u093e\u092f \u092f\u093e \u0935\u0947\u092c\u0938\u093e\u0907\u091f/\u092a\u094b\u0930\u094d\u091f\u0932\u0935\u0930 \u0935\u0948\u0936\u093f\u0937\u094d\u091f\u094d\u092f\u0940\u0915\u0943\u0924 \u0938\u093e\u0939\u093f\u0924\u094d\u092f \u0915\u094b\u0920\u0947\u0939\u0940 \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u092a\u093e\u0926\u093f\u0924 \u0915\u0947\u0932\u0947 \u091c\u093e\u0923\u093e\u0930 \u0928\u093e\u0939\u0940. \u0924\u0925\u093e\u092a\u093f, \u091c\u0930 \u0938\u093e\u092e\u0917\u094d\u0930\u0940\u091a\u0940 \u092a\u0930\u0935\u093e\u0928\u0917\u0940 \u0918\u0947\u090a\u0928 \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u092a\u093e\u0926\u0928 \u0915\u0930\u093e\u092f\u091a\u0947 \u0905\u0938\u0947\u0932, \u0924\u0930 \u0905\u0938\u0947 \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u092a\u093e\u0926\u0928 \u0905\u091a\u0942\u0915\u092a\u0923\u0947 \u0915\u0947\u0932\u0947 \u092a\u093e\u0939\u093f\u091c\u0947 \u0906\u0923\u093f \u0905\u092a\u092e\u093e\u0928\u093e\u0938\u094d\u092a\u0926 \u0930\u0940\u0924\u0940\u0928\u0947 \u0915\u093f\u0902\u0935\u093e \u0926\u093f\u0936\u093e\u092d\u0942\u0932 \u0915\u0930\u0923\u093e\u0931\u094d\u092f\u093e \u0938\u0902\u0926\u0930\u094d\u092d\u093e\u0924 \u0935\u093e\u092a\u0930\u0932\u0947 \u091c\u093e\u090a \u0928\u092f\u0947. \u091c\u0947\u0925\u0947 \u0938\u093e\u092e\u0917\u094d\u0930\u0940 \u092a\u094d\u0930\u0915\u093e\u0936\u093f\u0924 \u0915\u0947\u0932\u0940 \u091c\u093e\u0924 \u0906\u0939\u0947 \u0915\u093f\u0902\u0935\u093e \u0907\u0924\u0930\u093e\u0902\u0928\u093e \u091c\u093e\u0930\u0940 \u0915\u0947\u0932\u0940 \u091c\u093e\u0924 \u0906\u0939\u0947, \u0924\u0947\u0925\u0947 \u0938\u094d\u0924\u094d\u0930\u094b\u0924 \u0920\u0933\u0915\u092a\u0923\u0947 \u092e\u093e\u0928\u094d\u092f \u0915\u0930\u0923\u0947 \u0906\u0935\u0936\u094d\u092f\u0915 \u0906\u0939\u0947. \u0924\u0925\u093e\u092a\u093f, \u092f\u093e \u0938\u093e\u092e\u0917\u094d\u0930\u0940\u091a\u0947 \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u092a\u093e\u0926\u0928 \u0915\u0930\u0923\u094d\u092f\u093e\u091a\u0940 \u092a\u0930\u0935\u093e\u0928\u0917\u0940 \u0924\u0943\u0924\u0940\u092f \u092a\u0915\u094d\u0937\u093e\u091a\u093e \u0915\u0949\u092a\u0940\u0930\u093e\u0907\u091f (\u0935\u093e\u092a\u0930\u0915\u0930\u094d\u0924\u094d\u092f\u093e\u0928\u0947 \u0938\u092c\u092e\u093f\u091f \u0915\u0947\u0932\u0947\u0932\u0940 \u0938\u093e\u092e\u0917\u094d\u0930\u0940) \u092e\u094d\u0939\u0923\u0942\u0928 \u0913\u0933\u0916\u0932\u094d\u092f\u093e \u091c\u093e\u0923\u093e\u0930\u094d\u200d\u092f\u093e \u0915\u094b\u0923\u0924\u094d\u092f\u093e\u0939\u0940 \u0938\u093e\u092e\u0917\u094d\u0930\u0940\u092a\u0930\u094d\u092f\u0902\u0924 \u0935\u093f\u0938\u094d\u0924\u093e\u0930\u093f\u0924 \u0939\u094b\u0923\u093e\u0930 \u0928\u093e\u0939\u0940. \u0905\u0936\u093e \u0938\u093e\u092e\u0917\u094d\u0930\u0940\u091a\u0947 \u092a\u0941\u0928\u0930\u0941\u0924\u094d\u092a\u093e\u0926\u0928 \u0915\u0930\u0923\u094d\u092f\u093e\u0938\u093e\u0920\u0940 \u0905\u0927\u093f\u0915\u0943\u0924\u0924\u093e \u0938\u0902\u092c\u0902\u0927\u093f\u0924 \u0915\u0949\u092a\u0940\u0930\u093e\u0907\u091f \u0927\u093e\u0930\u0915\u093e\u0915\u0921\u0942\u0928 \u092a\u094d\u0930\u093e\u092a\u094d\u0924 \u0915\u0930\u0923\u0947 \u0906\u0935\u0936\u094d\u092f\u0915 \u0906\u0939\u0947.","Hyperlink":"\u0939\u093e\u092f\u092a\u0930\u0932\u093f\u0902\u0915\u093f\u0902\u0917 \u0927\u094b\u0930\u0923","HyperlinkTextLink":"\u092c\u093e\u0939\u094d\u092f \u0935\u0947\u092c\u0938\u093e\u0907\u091f\u094d\u0938/\u092a\u094b\u0930\u094d\u091f\u0932\u091a\u094d\u092f\u093e \u0932\u093f\u0902\u0915\u094d\u0938","hyperLinkPSub1":"\u092c\u093e\u0939\u094d\u092f \u0935\u0947\u092c\u0938\u093e\u0907\u091f\u094d\u0938/\u092a\u094b\u0930\u094d\u091f\u0932\u091a\u094d\u092f\u093e \u0932\u093f\u0902\u0915\u094d\u0938","hyperLinkPSub2":"\u0907\u0924\u0930 \u0935\u0947\u092c\u0938\u093e\u0907\u091f\u094d\u0938/\u092a\u094b\u0930\u094d\u091f\u0932\u0926\u094d\u0935\u093e\u0930\u0947 \u092a\u0930\u093f\u091a\u092f \u091a\u094d\u092f\u093e \u0932\u093f\u0902\u0915\u094d\u0938","HyperlinkText":"<b><i>\u092a\u0930\u093f\u091a\u092f</i></b> \u0935\u0930 \u0915\u093e\u0939\u0940 \u0920\u093f\u0915\u093e\u0923\u0940, \u0924\u0941\u092e\u094d\u0939\u093e\u0932\u093e \u0907\u0924\u0930 \u0935\u0947\u092c\u0938\u093e\u0907\u091f/\u092a\u094b\u0930\u094d\u091f\u0932\u091a\u094d\u092f\u093e \u0932\u093f\u0902\u0915\u094d\u0938 \u092e\u093f\u0933\u0924\u0940\u0932. \u0924\u0941\u092e\u091a\u094d\u092f\u093e \u0938\u094b\u092f\u0940\u0938\u093e\u0920\u0940 \u092f\u093e \u0932\u093f\u0902\u0915\u094d\u0938 \u0926\u093f\u0932\u094d\u092f\u093e \u0906\u0939\u0947\u0924. <b><i>\u092a\u0930\u093f\u091a\u092f</i></b> \u0932\u093f\u0902\u0915 \u0915\u0947\u0932\u0947\u0932\u094d\u092f\u093e \u0935\u0947\u092c\u0938\u093e\u0907\u091f\u094d\u0938/\u0938\u0947\u0935\u093e\u0902\u091a\u094d\u092f\u093e \u092e\u091c\u0915\u0941\u0930\u093e\u0938\u093e\u0920\u0940 \u091c\u092c\u093e\u092c\u0926\u093e\u0930 \u0928\u093e\u0939\u0940 \u0906\u0923\u093f \u0924\u094d\u092f\u093e\u0924 \u0935\u094d\u092f\u0915\u094d\u0924 \u0915\u0947\u0932\u0947\u0932\u094d\u092f\u093e \u092e\u0924\u093e\u0902\u091a\u0947 \u0938\u092e\u0930\u094d\u0925\u0928 \u0915\u0930\u0923\u0947 \u0906\u0935\u0936\u094d\u092f\u0915 \u0928\u093e\u0939\u0940. \u092f\u093e \u0935\u0947\u092c\u0938\u093e\u0907\u091f\u0935\u0930\u0940\u0932 \u0926\u0941\u0935\u094d\u092f\u093e\u091a\u0940 \u0915\u093f\u0902\u0935\u093e \u0924\u094d\u092f\u093e\u091a\u0940 \u0938\u0942\u091a\u0940\u091a\u0940 \u0915\u0947\u0935\u0933 \u0909\u092a\u0938\u094d\u0925\u093f\u0924\u0940 \u0939\u0947 \u0915\u094b\u0923\u0924\u094d\u092f\u093e\u0939\u0940 \u092a\u094d\u0930\u0915\u093e\u0930\u091a\u0947 \u0938\u092e\u0930\u094d\u0925\u0928 \u092e\u093e\u0928\u0932\u0947 \u091c\u093e\u090a \u0928\u092f\u0947. \u0906\u092e\u094d\u0939\u0940 \u0939\u092e\u0940 \u0926\u0947\u090a \u0936\u0915\u0924 \u0928\u093e\u0939\u0940 \u0915\u0940 \u0939\u0947 \u0926\u0941\u0935\u0947 \u0928\u0947\u0939\u092e\u0940 \u0915\u093e\u0930\u094d\u092f \u0915\u0930\u0924\u0940\u0932 \u0906\u0923\u093f \u0906\u092e\u091a\u094d\u092f\u093e\u0915\u0921\u0947 \u0932\u093f\u0902\u0915 \u0915\u0947\u0932\u0947\u0932\u094d\u092f\u093e \u0917\u0902\u0924\u0935\u094d\u092f\u0938\u094d\u0925\u093e\u0928\u093e\u0902\u091a\u094d\u092f\u093e \u0905\u0924\u093f\u0909\u092a\u0932\u092c\u094d\u0927\u0924\u0947\u0935\u0930 \u0928\u093f\u092f\u0902\u0924\u094d\u0930\u0923 \u0928\u093e\u0939\u0940.","linkToParichay":"\u0907\u0924\u0930 \u0935\u0947\u092c\u0938\u093e\u0907\u091f/\u092a\u094b\u0930\u094d\u091f\u0932\u0926\u094d\u0935\u093e\u0930\u0947 \u092a\u0930\u093f\u091a\u092f\u091a\u094d\u092f\u093e \u0932\u093f\u0902\u0915\u094d\u0938","linkToParichayText":"\u092f\u093e \u0935\u0947\u092c\u0938\u093e\u0908\u091f\u0935\u0930 \u0939\u094b\u0938\u094d\u091f \u0915\u0947\u0932\u0947\u0932\u094d\u092f\u093e \u092e\u093e\u0939\u093f\u0924\u0940\u0936\u0940 \u0924\u0941\u092e\u094d\u0939\u0940 \u0925\u0947\u091f \u0932\u093f\u0902\u09